# .dockerignore
# Files listed here are excluded from the Docker build context.
# Smaller context = faster docker build (less data sent to the daemon).

# Git metadata (not needed inside the image)
.git
.gitignore

# Build artifacts on the host (we build fresh inside the container)
build/
install/
log/

# Editor and OS noise
.vscode/
__pycache__/
*.pyc
.DS_Store
